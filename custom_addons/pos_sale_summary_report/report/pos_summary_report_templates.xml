<odoo>
  <template id="summary_template">
    <t t-call="web.basic_layout">
      <t t-foreach="docs" t-as="doc">
        <div class="page">
          <h2>POS Daily Summary Report</h2>

          <p>Date From: <t t-esc="date_from or ''"/></p>
          <p>Date To: <t t-esc="date_to or ''"/></p>
          <p>POS: <t t-esc="config_names or ''"/></p>
          <p>Orders: <t t-esc="order_count or 0"/></p>

          <t t-if="not summary_by_date">
            <p><em>No POS orders found for the selected date range and configuration.</em></p>
          </t>

          <t t-if="summary_by_date">
            <t t-foreach="summary_by_date.items()" t-as="date_group">
              <t t-set="date" t-value="date_group[0]"/>
              <t t-set="lines" t-value="date_group[1]"/>
              <h4>Date: <t t-esc="date"/></h4>
              <table class="table table-sm">
                <thead>
                  <tr>
                    <th>Product</th>
                    <th>Qty</th>
                    <th>Total</th>
                  </tr>
                </thead>
                <tbody>
                  <tr t-foreach="lines" t-as="line">
                    <td><t t-esc="line['product_name']"/></td>
                    <td><t t-esc="line['qty']"/></td>
                    <td><t t-esc="line['total']"/></td>
                  </tr>
                </tbody>
              </table>
            </t>
          </t>

          <h4>Orders Pending Invoicing (with VAT products)</h4>
          <t t-if="not pending_orders">
            <p><em>No pending invoicing orders in this period.</em></p>
          </t>
          <t t-if="pending_orders">
            <table class="table table-sm">
              <thead>
                <tr>
                  <th>Order</th>
                  <th>Date</th>
                  <th>Customer</th>
                  <th>Tax ID</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                <tr t-foreach="pending_orders" t-as="po">
                  <td><t t-esc="po['name']"/></td>
                  <td><t t-esc="po['date_order']"/></td>
                  <td><t t-esc="po['customer']"/></td>
                  <td><t t-esc="po['vat']"/></td>
                  <td><t t-esc="po['amount_total']"/></td>
                </tr>
              </tbody>
            </table>
          </t>
        </div>
      </t>
    </t>
  </template>
</odoo>
