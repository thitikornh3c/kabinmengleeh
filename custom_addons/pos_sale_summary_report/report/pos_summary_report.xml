<odoo>
    <data>
        <record id="action_pos_summary_report" model="ir.actions.report">
            <field name="name">POS Sales Summary Styled</field>
            <field name="model">pos.summary.wizard</field> 
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">pos_sale_summary_report.summary_template</field>
            <field name="report_file">pos_sale_summary_report.summary_template</field>
            <field name="print_report_name">'POS_Summary_%s_%s' % (object.date_from or '', object.date_to or '')</field>
            <field name="paperformat_id" ref="pos_sale_summary_report.paperformat_pos_summary"/>
        </record>
    </data>
</odoo>
