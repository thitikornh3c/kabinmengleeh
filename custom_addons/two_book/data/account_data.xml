<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="fiscal_position_vat_th" model="account.fiscal.position">
            <field name="name">ขายในประเทศ - VAT 7% (ใบกำกับภาษี)</field>
            <field name="note">สำหรับการขายที่ต้องออกใบกำกับภาษีเต็มรูปแบบ อัตรา 7%</field>
            <field name="auto_apply" eval="False"/>
        </record>

        <record id="fiscal_position_non_vat_th" model="account.fiscal.position">
            <field name="name">ขายในประเทศ - Non-VAT (บิลเงินสด)</field>
            <field name="note">สำหรับการขายที่ไม่ออกใบกำกับภาษี (ลูกค้าทั่วไป/ช่าง)</field>
            <field name="auto_apply" eval="False"/>
        </record>

        <record id="journal_non_vat_sales" model="account.journal">
            <field name="name">ยอดขาย Non-VAT (บิลเงินสด)</field>
            <field name="code">NVAT</field>
            <field name="type">sale</field>
            <field name="sequence" eval="20"/>
        </record>

        <record id="account_vat_clearing" model="account.account">
            <field name="code">VATCLR</field>
            <field name="name">พักรายได้ VAT รอออกใบกำกับ</field>
            <field name="account_type">liability_current</field>
            <field name="reconcile" eval="True"/>
        </record>

    </data>
</odoo>
