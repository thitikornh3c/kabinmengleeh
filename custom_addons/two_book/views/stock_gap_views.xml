<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_two_book_stock_gap_list" model="ir.ui.view">
        <field name="name">two.book.stock.gap.list</field>
        <field name="model">two.book.stock.gap</field>
        <field name="arch" type="xml">
            <list string="Stock Gap (Non-VAT)" decoration-muted="state == 'reconciled'">
                <field name="create_date"/>
                <field name="pos_order_id"/>
                <field name="session_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'open'"
                       decoration-success="state == 'reconciled'"/>
            </list>
        </field>
    </record>

    <record id="view_two_book_stock_gap_pivot" model="ir.ui.view">
        <field name="name">two.book.stock.gap.pivot</field>
        <field name="model">two.book.stock.gap</field>
        <field name="arch" type="xml">
            <pivot string="สรุป Stock Gap">
                <field name="product_id" type="row"/>
                <field name="session_id" type="col"/>
                <field name="quantity" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_two_book_stock_gap" model="ir.actions.act_window">
        <field name="name">Stock Gap (Two Book)</field>
        <field name="res_model">two.book.stock.gap</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[('state', '=', 'open')]</field>
        <field name="context">{'search_default_group_product': 1}</field>
    </record>

    <menuitem
        id="menu_two_book_stock_gap"
        name="Stock Gap (Non-VAT)"
        parent="point_of_sale.menu_point_of_sale"
        action="action_two_book_stock_gap"
        sequence="55"
    />

</odoo>
