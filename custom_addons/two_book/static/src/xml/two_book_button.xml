<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="two_book.TwoBookButton">
        <div class="two-book-container" t-if="twoBookEnabled">
            <button
                t-att-class="buttonClass"
                t-on-click="toggleVatMode"
                t-att-title="buttonLabel"
            >
                <i t-attf-class="fa {{ isVatOrder ? 'fa-file-text-o' : 'fa-money' }} me-1"/>
                <span t-esc="buttonLabel"/>
            </button>
        </div>
    </t>

    <t t-name="two_book.ActionpadWidget" t-inherit="point_of_sale.ActionpadWidget" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('actionpad')]" position="inside">
            <TwoBookButton/>
        </xpath>
    </t>

</templates>
