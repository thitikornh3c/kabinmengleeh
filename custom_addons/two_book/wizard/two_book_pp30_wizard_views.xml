<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_two_book_pp30_wizard_form" model="ir.ui.view">
        <field name="name">two.book.pp30.wizard.form</field>
        <field name="model">two.book.pp30.wizard</field>
        <field name="arch" type="xml">
            <form string="แบบ ภ.พ.30 (2568)">
                <group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="branch_code"/>
                    </group>
                    <group>
                        <field name="overpaid_carryforward"/>
                        <field name="filing_normal"/>
                        <field name="supplementary_no" invisible="filing_normal"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <div class="alert alert-info" role="alert">
                    สร้างแบบตามโครงสร้าง
                    <strong>ภ.พ.30 ปรับปรุง 2568</strong>
                    (ช่อง 1–16 + ใบแนบ) จาก Invoice/Bill ที่ Posted ใน Odoo
                    — ยื่นจริงผ่าน RD e-Filing
                </div>
                <footer>
                    <button name="action_print"
                            string="Print ภ.พ.30"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_two_book_pp30_wizard" model="ir.actions.act_window">
        <field name="name">แบบ ภ.พ.30 (2568)</field>
        <field name="res_model">two.book.pp30.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_two_book_pp30"
        name="Print ภ.พ.30 (2568)"
        parent="menu_two_book_summary_root"
        action="action_two_book_pp30_wizard"
        sequence="55"/>

    <menuitem
        id="menu_two_book_pp30_reporting"
        name="Print ภ.พ.30 (2568)"
        parent="point_of_sale.menu_point_root"
        action="action_two_book_pp30_wizard"
        sequence="25"/>

</odoo>
