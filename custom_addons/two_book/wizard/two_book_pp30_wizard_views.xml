<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_two_book_pp30_wizard_form" model="ir.ui.view">
        <field name="name">two.book.pp30.wizard.form</field>
        <field name="model">two.book.pp30.wizard</field>
        <field name="arch" type="xml">
            <form string="รายงาน ภ.พ.30">
                <group>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button name="action_print"
                            string="Print PDF"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_two_book_pp30_wizard" model="ir.actions.act_window">
        <field name="name">รายงาน ภ.พ.30</field>
        <field name="res_model">two.book.pp30.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_two_book_pp30"
        name="รายงาน ภ.พ.30"
        parent="menu_two_book_summary_root"
        action="action_two_book_pp30_wizard"
        sequence="60"
        groups="account.group_account_invoice,point_of_sale.group_pos_manager"/>

</odoo>
